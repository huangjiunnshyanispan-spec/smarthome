<!DOCTYPE html>
<html lang="zh-tw">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>燈光控制系統</title>
    <link rel="stylesheet" href="/styles.css">
    <script src="/socket.io/socket.io.js"></script>
</head>
<body>
    <div class="container">
        <h1>燈光控制系統</h1>
        <a href="/" class="back-btn">返回儀表板</a>
        <div class="device-details">
            <h3>目前狀態：</h3>
            <% const isOnline = signal && !/^(離線|offline)$/i.test(String(signal).trim()); %>
            <div id="statusDisplay" class="status-box <%= isOnline ? 'status-online' : 'status-offline' %>">
                <%= isOnline ? '連線' : '離線' %>
            </div>
        </div>

        <div class="controls">
            <h3>燈光控制：</h3>
            <div class="button-group" style="display: flex; gap: 16px;">
                <button class="photo-btn" style="background-color: #4caf50; color: #fff; border: none;" onclick="sendControl('light_on')">開燈</button>
                <button class="photo-btn" style="background-color: #f44336; color: #fff; border: none;" onclick="sendControl('light_off')">關燈</button>
            </div>
        </div>
    </div>

    <script>
        const socket = io();
        const deviceKey = 'lighting';

        socket.on('updateSignals', (data) => {
            if (data[deviceKey] === undefined) return;

            const status = data[deviceKey];
            const normalizedStatus = String(status ?? '').trim().toLowerCase();
            const isOnline = normalizedStatus !== '' && normalizedStatus !== '離線' && normalizedStatus !== 'offline';
            const statusDisplay = document.getElementById('statusDisplay');

            statusDisplay.innerText = isOnline ? '連線' : '離線';
            statusDisplay.className = 'status-box ' + (isOnline ? 'status-online' : 'status-offline');
        });

        function sendControl(command) {
            socket.emit('webControl', {
                device: deviceKey,
                cmd: command
            });
            console.log('發送燈光指令:', command);
        }
    </script>
</body>
</html>
